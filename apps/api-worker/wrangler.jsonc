{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "contexted-api",
  "main": "src/worker.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],

  // Hyperdrive binding for Postgres connection pooling
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "<HYPERDRIVE_ID>"
    }
  ],

  "env": {
    "staging": {
      "name": "contexted-api-staging",
      "vars": {
        "APP_MODE": "postgres",
        "SUPABASE_STORAGE_BUCKET": "raw-ingestion-staging"
      }
    },
    "production": {
      "name": "contexted-api",
      "vars": {
        "APP_MODE": "postgres",
        "APP_PUBLIC_ORIGIN": "https://contexted.app",
        "SUPABASE_STORAGE_BUCKET": "raw-ingestion-staging",
        "LLM_PRIMARY": "openai"
      }
    }
  }
}
