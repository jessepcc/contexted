# Runtime mode: "memory" (in-memory, no DB needed) or "postgres" (real Supabase)
APP_MODE=memory

# Supabase auth (required when APP_MODE=postgres)
# Use .env.test or .env.production for environment-specific values
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=raw-ingestion-staging
SUPABASE_DB_PW=

# Postgres (required when APP_MODE=postgres)
DATABASE_URL=

# Queue dispatcher endpoint for Cloudflare Queues fan-out
QUEUE_DISPATCH_URL=
QUEUE_DISPATCH_TOKEN=

# AI providers
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
ANTHROPIC_LLM_MODEL=claude-3-5-haiku-latest
LLM_PRIMARY=openai

# App config
MAX_UPLOAD_MB=64
SIGNED_UPLOAD_TTL_SEC=300
RAW_POLICY_VERSION=raw-v1
RAW_MODE_DEFAULT=ttl_object_storage
RAW_HARD_TTL_MINUTES=60
CHAT_POLL_FOREGROUND_SEC=5
CHAT_POLL_BACKGROUND_SEC=30
PROCESSING_POLL_MS=2000
MAX_JSON_BODY_BYTES=131072
MATCH_TOP_K=20
INTERNAL_ADMIN_TOKEN=
